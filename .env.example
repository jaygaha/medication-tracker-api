# Server
APP_NAME="Medication Tracker"
API_PORT=5010
API_PUBLISHED_PORT=5010
ENV=development
LOG_LEVEL=debug

COMPOSE_PROJECT_NAME=medsys

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=med_sys
POSTGRES_PORT=5432
POSTGRES_PUBLISHED_PORT=5402

# Redis
REDIS_PORT=6379
REDIS_PUBLISHED_PORT=6302
REDIS_PASSWORD=
REDIS_PREFIX=''
REDIS_URL=redis://redis:6379
REDIS_MAX_RETRIES=3

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Notifications
APNs_KEY_ID=your_apns_key_id
APNs_TEAM_ID=your_team_id
FCM_API_KEY=your_fcm_key
